# GitHub Actions repository SECRETS for the wedding site.
# Copy to .env.secrets, fill in real values, then push:
#   gh secret set -f .env.secrets
# The filled .env.secrets is gitignored -- never commit real secrets.

# Admin dashboard password (used at /admin/login).
ADMIN_TOKEN=

# listmonk API access token (listmonk: Admin -> Settings -> API users).
LISTMONK_TOKEN=
