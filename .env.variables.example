# GitHub Actions repository VARIABLES for the wedding site (non-secret).
# Copy to .env.variables, fill in, then push:
#   gh variable set -f .env.variables
# The filled .env.variables is gitignored.

# Base URL of your listmonk instance.
LISTMONK_URL=https://mailing.tylerrouze.com

# listmonk API username.
LISTMONK_USER=

# Target mailing list id (the wedding list).
LISTMONK_LIST_ID=4

# Optional. Omit to use the in-app default (sqlite:data/wedding.db).
# DATABASE_URL=sqlite:data/wedding.db

# Pre-launch DB wipe toggle (see deploy.yml). Leave commented; set ad hoc with
#   gh variable set RESET_DB --body true
# and delete it once the site is live.
# RESET_DB=true
